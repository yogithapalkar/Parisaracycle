<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/statsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFFFFF">

            <!-- App Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 ParisaraCycle"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="8dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="12dp"/>

            <!-- CO2 Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#F1F8E9"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCO2Today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g CO2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#E8F5E9"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THIS MONTH"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCO2Month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g CO2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Buttons Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnReport"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="📋 Report"
                    android:backgroundTint="#E53935"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnPitStop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🔧 Pit Stops"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Buttons Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCO2"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🌱 CO2 Tracker"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnBuddy"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🤝 Buddy System"
                    android:backgroundTint="#6A1B9A"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>